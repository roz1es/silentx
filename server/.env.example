# BrenksChat email delivery.
# Recommended for VPS: Resend works through HTTPS and is not affected by SMTP blocks.
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_resend_api_key
MAIL_FROM=BrenksChat <no-reply@silentx.ru>
EMAIL_HTTP_TIMEOUT_MS=8000

# For Gmail use a Google account with 2FA enabled and create an App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=brenkschat@gmail.com
SMTP_PASS=your_google_app_password
SMTP_TIMEOUT_MS=8000
ALLOW_ADMIN_LOGIN_WITHOUT_EMAIL=false

# Browser origins allowed to call the API and Socket.IO.
CLIENT_ORIGINS=https://silentx.ru,https://www.silentx.ru,http://localhost:5173

# Generate these once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_public_vapid_key
VAPID_PRIVATE_KEY=your_private_vapid_key
VAPID_SUBJECT=mailto:no-reply@silentx.ru
